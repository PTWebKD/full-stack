        <!-- Fallback annotation -->
        <mxCell id="fallback" value="Fallback 2 lớp: không đủ sản phẩm an toàn → nới ràng buộc (personalized query)&#xa;không xác định được nhóm cơ (không có session/lịch sử) → Best-seller toàn nền tảng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
